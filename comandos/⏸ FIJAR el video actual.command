#!/bin/bash
# Doble-click: fija el video que está puesto ahora. No rota hasta que reanudes.
cd "$(dirname "$0")"
touch "PAUSA"
echo ""
echo "  ⏸  ROTACION EN PAUSA"
echo ""
echo "  El fondo de la pantalla de bloqueo queda fijo en el video actual."
echo "  Para volver a rotar, doble-click en:  ▶ REANUDAR la rotacion.command"
echo ""
echo "  (Podes cerrar esta ventana)"
